<section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
  <div class="flex flex-col gap-5 md:flex-row md:items-start">
    <div class="shrink-0 self-center md:self-start">
      <%= render "books/thumbnail",
                 title: book.title,
                 thumbnail: book.thumbnail,
                 url: nil,
                 size: :large,
                 link: false,
                 extra_classes: "shadow-sm" %>
    </div>

    <div class="min-w-0 flex-1">
      <h1 class="text-2xl font-semibold leading-tight tracking-tight text-stone-900 sm:text-3xl"><%= book.title %></h1>

      <div class="mt-3 space-y-1 text-sm leading-6 text-stone-500">
        <p><%= t("books.show.authors") %>: <%= book.authors_text.presence || "-" %></p>
        <p><%= t("books.show.publisher") %>: <%= book.publisher.presence || "-" %></p>
        <p><%= t("books.show.isbn") %>: <%= book.isbn.presence || "-" %></p>
      </div>

      <p class="mt-5 border-t border-stone-100 pt-4 text-sm leading-7 text-stone-700"><%= book.description.presence || t("books.show.empty_description") %></p>

      <% if book.external_url.present? %>
        <div class="mt-5">
          <%= link_to t("books.show.external_link"), book.external_url, target: "_blank", rel: "noopener", class: "text-sm font-medium text-stone-900" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
