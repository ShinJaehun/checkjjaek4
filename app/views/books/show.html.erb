<section class="mx-auto flex w-full max-w-5xl flex-col gap-6">
  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <div class="flex flex-col gap-5 md:flex-row">
      <% if @book.thumbnail.present? %>
        <img src="<%= @book.thumbnail %>" alt="<%= @book.title %>" class="w-32 rounded-3xl border border-stone-200 object-cover" />
      <% end %>

      <div class="min-w-0 flex-1">
        <p class="text-sm uppercase tracking-[0.3em] text-stone-400"><%= t("books.show.eyebrow") %></p>
        <h1 class="mt-2 text-3xl font-semibold tracking-tight text-stone-900"><%= @book.title %></h1>
        <div class="mt-4 space-y-1 text-sm text-stone-500">
          <p><%= t("books.show.authors") %>: <%= @book.authors_text.presence || "-" %></p>
          <p><%= t("books.show.publisher") %>: <%= @book.publisher.presence || "-" %></p>
          <p><%= t("books.show.isbn") %>: <%= @book.isbn.presence || "-" %></p>
        </div>
        <p class="mt-4 text-sm leading-6 text-stone-700"><%= @book.description.presence || t("books.show.empty_description") %></p>

        <% if @book.external_url.present? %>
          <div class="mt-4">
            <%= link_to t("books.show.external_link"), @book.external_url, target: "_blank", rel: "noopener", class: "text-sm font-medium text-stone-900" %>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <section class="grid gap-6 lg:grid-cols-[minmax(0,0.95fr)_minmax(320px,1.05fr)]">
    <div class="space-y-6">
      <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-stone-900"><%= t("books.show.state_title") %></h2>
        <p class="mt-1 text-sm text-stone-500"><%= t("books.show.state_description") %></p>

        <div class="mt-5">
          <%= render "bookshelf_entries/form",
                     bookshelf_entry: @bookshelf_entry,
                     book: @book,
                     sticker_definitions: @sticker_definitions,
                     submit_label: t("books.show.save_state") %>
        </div>
      </section>

      <section class="space-y-4">
        <div>
          <p class="text-sm uppercase tracking-[0.3em] text-stone-400"><%= t("books.show.timeline_eyebrow") %></p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-stone-900"><%= t("books.show.timeline_title") %></h2>
        </div>

        <% if @jjaeks.any? %>
          <% @jjaeks.each do |jjaek| %>
            <%= render "jjaeks/jjaek", jjaek: jjaek %>
          <% end %>
        <% else %>
          <section class="rounded-[2rem] border border-dashed border-stone-300 bg-white p-6 text-sm text-stone-500 shadow-sm">
            <%= t("books.show.empty_jjaeks") %>
          </section>
        <% end %>
      </section>
    </div>

    <aside>
      <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-stone-900"><%= t("books.show.new_jjaek_title") %></h2>
        <p class="mt-1 text-sm text-stone-500"><%= t("books.show.new_jjaek_description") %></p>

        <% if @quoted_jjaek.present? %>
          <div class="mt-4 rounded-2xl bg-stone-50 px-4 py-3 text-sm text-stone-600">
            <div class="font-medium text-stone-900"><%= t("books.show.requote_source", name: @quoted_jjaek.user.name) %></div>
            <p class="mt-2 line-clamp-4 whitespace-pre-wrap"><%= @quoted_jjaek.content %></p>
          </div>
        <% end %>

        <div class="mt-5">
          <%= form_with model: @jjaek, class: "space-y-4" do |form| %>
            <% if @jjaek.errors.any? %>
              <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                <%= @jjaek.errors.full_messages.to_sentence %>
              </div>
            <% end %>

            <%= form.hidden_field :book_id, value: @book.id %>
            <%= form.hidden_field :quoted_jjaek_id, value: @quoted_jjaek&.id %>

            <div class="space-y-2">
              <%= form.label :visibility, t("jjaeks.form.visibility"), class: "text-sm font-medium text-stone-700" %>
              <%= form.select :visibility,
                              Jjaek.visibilities.keys.map { |visibility| [t("jjaeks.visibility.#{visibility}"), visibility] },
                              {},
                              class: "w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm shadow-sm focus:border-stone-500 focus:outline-none" %>
            </div>

            <div class="space-y-2">
              <%= form.label :content, t("jjaeks.form.content"), class: "text-sm font-medium text-stone-700" %>
              <%= form.text_area :content, rows: 8, class: "w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm shadow-sm focus:border-stone-500 focus:outline-none" %>
            </div>

            <%= form.submit t("jjaeks.actions.publish_short"), class: "rounded-full bg-stone-900 px-4 py-2 text-sm font-medium text-stone-50" %>
          <% end %>
        </div>
      </section>
    </aside>
  </section>
</section>
