<section class="mx-auto flex w-full max-w-6xl flex-col gap-6">
  <section class="grid gap-6 lg:grid-cols-[minmax(0,1.35fr)_minmax(320px,0.75fr)] lg:items-start">
    <%= render "books/book_header", book: @book %>

    <%= render "books/bookshelf_panel",
               book: @book,
               bookshelf_entry: @bookshelf_entry,
               bookshelves: @bookshelves,
               sticker_definitions: @sticker_definitions %>
  </section>

  <% if @bookshelf_entry.present? %>
    <section>
      <%= render "books/jjaek_form_panel", book: @book, jjaek: @jjaek, quoted_jjaek: @quoted_jjaek %>
    </section>
  <% end %>

  <%= render "books/timeline", jjaeks: @jjaeks %>
</section>
