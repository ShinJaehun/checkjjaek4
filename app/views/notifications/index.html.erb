<section class="mx-auto flex w-full max-w-4xl flex-col gap-6">
  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <p class="text-sm uppercase tracking-[0.3em] text-stone-400"><%= t("notifications.eyebrow") %></p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight text-stone-900"><%= t("notifications.title") %></h1>
  </section>

  <% if @notifications.any? %>
    <section class="space-y-3">
      <% @notifications.each do |notification| %>
        <article class="rounded-[2rem] border border-stone-200 bg-white p-5 shadow-sm">
          <%= link_to notification_target_path(notification), class: "block" do %>
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-medium text-stone-900"><%= notification_message(notification) %></p>
                <p class="mt-1 text-xs text-stone-500"><%= l(notification.created_at, format: :short) %></p>
              </div>
              <% if notification.unread? %>
                <span class="rounded-full bg-stone-900 px-2 py-1 text-[11px] font-semibold text-stone-50"><%= t("notifications.unread") %></span>
              <% end %>
            </div>
          <% end %>
        </article>
      <% end %>
    </section>
  <% else %>
    <section class="rounded-[2rem] border border-dashed border-stone-300 bg-white p-6 text-sm text-stone-500 shadow-sm">
      <%= t("notifications.empty") %>
    </section>
  <% end %>
</section>
