<section class="mx-auto flex w-full max-w-4xl flex-col gap-6">
  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <h1 class="text-3xl font-semibold tracking-tight text-stone-900"><%= t("notifications.title") %></h1>
    <p class="mt-3 text-sm text-stone-500"><%= t("notifications.description") %></p>
  </section>

  <% if @notifications.any? %>
    <section class="space-y-3">
      <% @notifications.each do |notification| %>
        <% unread_on_entry = @unread_notification_ids.include?(notification.id) %>
        <article class="rounded-[2rem] border border-stone-200 bg-white p-5 shadow-sm <%= "opacity-60" unless unread_on_entry %>">
          <%= link_to notification_target_path(notification), class: "block" do %>
            <div class="flex items-start justify-between gap-4">
              <div class="flex min-w-0 items-start gap-3">
                <% if notification.actor.present? %>
                  <%= user_avatar_image(notification.actor, size: 128, alt: notification.actor.name, class: "h-9 w-9 shrink-0 rounded-full object-cover") %>
                <% end %>

                <div>
                  <p class="text-sm font-medium text-stone-900"><%= notification_message(notification) %></p>
                  <p class="mt-1 text-xs text-stone-500"><%= l(notification.created_at, format: :short) %></p>
                </div>
              </div>
            </div>
          <% end %>
        </article>
      <% end %>
    </section>
  <% else %>
    <section class="rounded-[2rem] border border-dashed border-stone-300 bg-white p-6 text-sm text-stone-500 shadow-sm">
      <%= t("notifications.empty") %>
    </section>
  <% end %>
</section>
