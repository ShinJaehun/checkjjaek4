<header class="border-b border-stone-200 bg-white/80 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
    <%= link_to "checkjjaek4", root_path, class: "text-xl font-semibold tracking-tight text-stone-900" %>
    <nav class="flex items-center gap-3 text-sm text-stone-700">
      <% if user_signed_in? %>
        <%= link_to t("home.nav"), root_path, class: "font-medium" %>
        <%= link_to t("book_search.nav"), book_search_path, class: "font-medium" %>
        <%= link_to t("bookshelf_entries.nav"), user_library_path(current_user), class: "font-medium" %>
        <%= link_to t("relationships.nav"), relationships_path, class: "font-medium" %>
        <%= link_to notifications_path, class: "font-medium" do %>
          <span><%= t("notifications.nav") %></span>
          <span id="notification-badge-container">
            <%= render "shared/notification_badge" %>
          </span>
        <% end %>
        <%= link_to user_path(current_user), class: "flex items-center gap-2 font-medium" do %>
          <%= user_avatar_image(current_user, size: 128, alt: current_user.name, class: "h-8 w-8 rounded-full object-cover") %>
          <span class="hidden sm:inline"><%= current_user.name %></span>
        <% end %>
        <%= button_to t("auth.actions.sign_out"), destroy_user_session_path, method: :delete, class: "rounded-full border border-stone-300 px-3 py-1.5" %>
      <% else %>
        <%= link_to t("auth.actions.sign_in"), new_user_session_path, class: "rounded-full border border-stone-300 px-3 py-1.5" %>
        <%= link_to t("auth.actions.sign_up"), new_user_registration_path, class: "rounded-full bg-stone-900 px-3 py-1.5 text-stone-50" %>
      <% end %>
    </nav>
  </div>
</header>
