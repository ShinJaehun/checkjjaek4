<section class="mx-auto max-w-3xl space-y-6 px-4 py-8">
  <div class="space-y-2">
    <h1 class="text-3xl font-semibold tracking-tight text-stone-900"><%= t("requotes.index.title") %></h1>
    <p class="text-sm text-stone-500"><%= t("requotes.index.description") %></p>
  </div>

  <section class="space-y-3">
    <%= render "jjaeks/quoted_jjaek", quoted_jjaek: @jjaek %>
  </section>

  <section class="space-y-4">
    <% if @requotes.any? %>
      <% @requotes.each do |jjaek| %>
        <%= render "jjaeks/jjaek", jjaek: jjaek %>
      <% end %>
    <% else %>
      <section class="rounded-[2rem] border border-dashed border-stone-300 bg-white p-6 text-sm text-stone-500 shadow-sm">
        <%= t("requotes.index.empty") %>
      </section>
    <% end %>
  </section>
</section>
