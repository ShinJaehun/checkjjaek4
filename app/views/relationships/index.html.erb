<section class="mx-auto flex w-full max-w-5xl flex-col gap-8">
  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <p class="text-sm uppercase tracking-[0.3em] text-stone-400"><%= t("relationships.eyebrow") %></p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight text-stone-900"><%= t("relationships.title") %></h1>
  </section>

  <section id="received-book-friend-requests" class="space-y-4">
    <h2 class="text-2xl font-semibold tracking-tight text-stone-900"><%= t("relationships.sections.received_book_friend_requests") %></h2>
    <% if @received_book_friend_requests.any? %>
      <% @received_book_friend_requests.each do |friendship| %>
        <article class="rounded-[2rem] border border-stone-200 bg-white p-5 shadow-sm">
          <div class="flex items-center justify-between gap-4">
            <%= link_to friendship.requester.name, user_path(friendship.requester), class: "font-medium text-stone-900" %>
            <div class="flex flex-wrap gap-3">
              <%= button_to t("users.actions.accept_book_friend"),
                            user_book_friendship_path(friendship.requester),
                            method: :patch,
                            params: { return_to: "relationships" },
                            class: "rounded-full bg-stone-900 px-4 py-2 text-sm font-medium text-stone-50" %>
              <%= button_to t("users.actions.reject_book_friend_request"),
                            user_book_friendship_path(friendship.requester),
                            method: :delete,
                            params: { return_to: "relationships" },
                            class: "rounded-full border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700" %>
            </div>
          </div>
        </article>
      <% end %>
    <% else %>
      <section class="rounded-[2rem] border border-dashed border-stone-300 bg-white p-6 text-sm text-stone-500 shadow-sm">
        <%= t("relationships.empty.received_book_friend_requests") %>
      </section>
    <% end %>
  </section>

  <section id="sent-book-friend-requests" class="space-y-4">
    <h2 class="text-2xl font-semibold tracking-tight text-stone-900"><%= t("relationships.sections.sent_book_friend_requests") %></h2>
    <% if @sent_book_friend_requests.any? %>
      <% @sent_book_friend_requests.each do |friendship| %>
        <article class="rounded-[2rem] border border-stone-200 bg-white p-5 shadow-sm">
          <div class="flex items-center justify-between gap-4">
            <%= link_to friendship.addressee.name, user_path(friendship.addressee), class: "font-medium text-stone-900" %>
            <%= button_to t("users.actions.cancel_book_friend_request"),
                          user_book_friendship_path(friendship.addressee),
                          method: :delete,
                          params: { return_to: "relationships" },
                          class: "rounded-full border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700" %>
          </div>
        </article>
      <% end %>
    <% else %>
      <section class="rounded-[2rem] border border-dashed border-stone-300 bg-white p-6 text-sm text-stone-500 shadow-sm">
        <%= t("relationships.empty.sent_book_friend_requests") %>
      </section>
    <% end %>
  </section>

  <section id="book-friends" class="space-y-4">
    <h2 class="text-2xl font-semibold tracking-tight text-stone-900"><%= t("relationships.sections.book_friends") %></h2>
    <% if @book_friends.any? %>
      <% @book_friends.each do |book_friend| %>
        <article class="rounded-[2rem] border border-stone-200 bg-white p-5 shadow-sm">
          <div class="flex items-center justify-between gap-4">
            <%= link_to book_friend.name, user_path(book_friend), class: "font-medium text-stone-900" %>
            <%= button_to t("users.actions.remove_book_friend"),
                          user_book_friendship_path(book_friend),
                          method: :delete,
                          params: { return_to: "relationships" },
                          class: "rounded-full border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700" %>
          </div>
        </article>
      <% end %>
    <% else %>
      <section class="rounded-[2rem] border border-dashed border-stone-300 bg-white p-6 text-sm text-stone-500 shadow-sm">
        <%= t("relationships.empty.book_friends") %>
      </section>
    <% end %>
  </section>

  <section id="following-users" class="space-y-4">
    <h2 class="text-2xl font-semibold tracking-tight text-stone-900"><%= t("relationships.sections.following_users") %></h2>
    <% if @following_users.any? %>
      <% @following_users.each do |followee| %>
        <article class="rounded-[2rem] border border-stone-200 bg-white p-5 shadow-sm">
          <div class="flex items-center justify-between gap-4">
            <%= link_to followee.name, user_path(followee), class: "font-medium text-stone-900" %>
            <%= button_to t("users.actions.unfollow"),
                          user_follow_path(followee),
                          method: :delete,
                          params: { return_to: "relationships" },
                          class: "rounded-full border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700" %>
          </div>
        </article>
      <% end %>
    <% else %>
      <section class="rounded-[2rem] border border-dashed border-stone-300 bg-white p-6 text-sm text-stone-500 shadow-sm">
        <%= t("relationships.empty.following_users") %>
      </section>
    <% end %>
  </section>

  <section id="followers" class="space-y-4">
    <h2 class="text-2xl font-semibold tracking-tight text-stone-900"><%= t("relationships.sections.followers") %></h2>
    <% if @followers.any? %>
      <% @followers.each do |follower| %>
        <article class="rounded-[2rem] border border-stone-200 bg-white p-5 shadow-sm">
          <%= link_to follower.name, user_path(follower), class: "font-medium text-stone-900" %>
        </article>
      <% end %>
    <% else %>
      <section class="rounded-[2rem] border border-dashed border-stone-300 bg-white p-6 text-sm text-stone-500 shadow-sm">
        <%= t("relationships.empty.followers") %>
      </section>
    <% end %>
  </section>
</section>
