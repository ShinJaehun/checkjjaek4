<section class="mx-auto flex w-full max-w-5xl flex-col gap-8">
  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <h1 class="text-3xl font-semibold tracking-tight text-stone-900"><%= t("relationships.title") %></h1>
    <p class="mt-3 text-sm text-stone-500"><%= t("relationships.description") %></p>
  </section>

  <%= render "relationships/section",
             section_id: "received-book-friend-requests",
             section_class: "scroll-mt-6 space-y-4",
             title: t("relationships.sections.received_book_friend_requests"),
             collection: @received_book_friend_requests,
             row_partial: "relationships/book_friend_request_row",
             row_locals: { direction: :received },
             empty_message: t("relationships.empty.received_book_friend_requests") %>

  <%= render "relationships/section",
             section_id: "sent-book-friend-requests",
             title: t("relationships.sections.sent_book_friend_requests"),
             collection: @sent_book_friend_requests,
             row_partial: "relationships/book_friend_request_row",
             row_locals: { direction: :sent },
             empty_message: t("relationships.empty.sent_book_friend_requests") %>

  <%= render "relationships/section",
             section_id: "book-friends",
             title: t("relationships.sections.book_friends"),
             collection: @book_friends,
             row_partial: "relationships/book_friend_row",
             empty_message: t("relationships.empty.book_friends") %>

  <%= render "relationships/section",
             section_id: "following-users",
             title: t("relationships.sections.following_users"),
             collection: @following_users,
             row_partial: "relationships/followee_row",
             empty_message: t("relationships.empty.following_users") %>

  <%= render "relationships/section",
             section_id: "followers",
             title: t("relationships.sections.followers"),
             collection: @followers,
             row_partial: "relationships/follower_row",
             empty_message: t("relationships.empty.followers") %>
</section>
