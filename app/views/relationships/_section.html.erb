<section id="<%= section_id %>" class="<%= local_assigns.fetch(:section_class, "space-y-4") %>">
  <h2 class="text-2xl font-semibold tracking-tight text-stone-900"><%= title %></h2>
  <% if collection.any? %>
    <% collection.each do |record| %>
      <%= render row_partial, local_assigns.fetch(:row_locals, {}).merge(record: record) %>
    <% end %>
  <% else %>
    <%= render "relationships/empty_state", message: empty_message %>
  <% end %>
</section>
