<article class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
  <div class="flex items-center justify-between gap-3">
    <div>
      <div class="text-sm font-semibold text-stone-900">
        <%= link_to post.user.name, user_path(post.user), class: "hover:text-stone-700" %>
      </div>
      <div class="text-xs text-stone-500"><%= l(post.created_at, format: :short) %></div>
    </div>

    <% if post.user == current_user %>
      <div class="flex items-center gap-2 text-xs text-stone-500">
        <%= link_to t("posts.actions.edit"), edit_post_path(post) %>
        <%= button_to t("posts.actions.delete"), post_path(post), method: :delete, form: { data: { turbo_confirm: t("posts.confirmations.destroy") } }, class: "text-red-600" %>
      </div>
    <% end %>
  </div>

  <div class="mt-4 whitespace-pre-wrap text-sm leading-6 text-stone-800"><%= post.content %></div>

  <div class="mt-4 flex items-center gap-4 text-xs text-stone-500">
    <span><%= t("posts.meta.likes", count: post.likes.size) %></span>
    <span><%= t("posts.meta.comments", count: post.comments.size) %></span>
    <%= like_button_for(post) %>
    <%= link_to t("posts.actions.view"), post_path(post), class: "font-medium text-stone-700" %>
  </div>
</article>
