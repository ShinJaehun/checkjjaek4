<section class="mx-auto flex w-full max-w-3xl flex-col gap-6">
  <%= render "post", post: @post %>

  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-stone-900"><%= t("comments.title") %></h2>

    <div class="mt-4 space-y-4">
      <% @post.comments.includes(:user).order(created_at: :asc).each do |comment| %>
        <article class="rounded-2xl bg-stone-50 px-4 py-3">
          <div class="flex items-center justify-between gap-3">
            <div class="text-sm font-medium text-stone-800"><%= comment.user.name %></div>
            <% if comment.user == current_user %>
              <%= button_to t("comments.actions.delete"), post_comment_path(@post, comment), method: :delete, class: "text-xs text-red-600" %>
            <% end %>
          </div>
          <p class="mt-2 text-sm leading-6 text-stone-700"><%= comment.content %></p>
        </article>
      <% end %>
    </div>

    <div class="mt-6">
      <%= form_with model: [@post, @comment], class: "space-y-3" do |form| %>
        <div class="space-y-2">
          <%= form.label :content, t("comments.form.content"), class: "text-sm font-medium text-stone-700" %>
          <%= form.text_area :content, rows: 3, class: "w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm shadow-sm focus:border-stone-500 focus:outline-none" %>
        </div>

        <%= form.submit t("comments.actions.submit"), class: "rounded-full bg-stone-900 px-4 py-2 text-sm font-medium text-stone-50" %>
      <% end %>
    </div>
  </section>
</section>
