<section class="grid gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(280px,0.9fr)]">
  <div class="space-y-6">
    <div class="rounded-[2rem] bg-stone-900 px-6 py-8 text-stone-50 shadow-lg">
      <p class="text-sm uppercase tracking-[0.3em] text-stone-300"><%= t("posts.index.eyebrow") %></p>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight"><%= t("posts.index.title") %></h1>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-stone-300"><%= t("posts.index.description") %></p>
    </div>

    <div class="space-y-4">
      <% @posts.each do |post| %>
        <%= render "post", post: post %>
      <% end %>
    </div>
  </div>

  <aside class="space-y-6">
    <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-stone-900"><%= t("posts.index.new_post_title") %></h2>
      <p class="mt-1 text-sm text-stone-500"><%= t("posts.index.new_post_description") %></p>
      <div class="mt-5">
        <%= render "form", post: @post, submit_label: t("posts.actions.publish") %>
      </div>
    </section>
  </aside>
</section>
