<% bookshelf_entry_count = local_assigns[:bookshelf_entry_count] || bookshelf_entries.size %>
<% bookshelf_view = @profile_bookshelf_view || "detail" %>

<section class="space-y-4">
  <header class="flex flex-wrap items-center gap-2 border-b border-stone-100 pb-4">
    <h3 class="break-words text-xl font-semibold text-stone-900"><%= bookshelf.name %></h3>
    <span class="rounded-full bg-stone-100 px-2.5 py-1 text-xs font-medium text-stone-600">
      <%= bookshelf_entry_count %>
    </span>
    <span class="rounded-full border border-stone-200 px-2.5 py-1 text-xs font-medium text-stone-500">
      <%= t("bookshelves.visibility.#{bookshelf.visibility}") %>
    </span>
  </header>

  <% if bookshelf_entries.any? %>
    <div class="grid gap-2 <%= bookshelf_view == "compact" ? "grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5" : "sm:grid-cols-2" %>">
      <% bookshelf_entries.each do |bookshelf_entry| %>
        <div class="space-y-2">
          <div class="min-h-4 rounded-xl border border-transparent transition-all duration-150"
               data-action="dragover->bookshelf-dnd#dragoverInsertSlot dragleave->bookshelf-dnd#dragleaveInsertSlot drop->bookshelf-dnd#dropOnInsertSlot"
               data-bookshelf-dnd-before-entry-id-param="<%= bookshelf_entry.id %>"></div>
          <%= render "bookshelf_entries/#{bookshelf_view == "compact" ? "compact_bookshelf_entry" : "profile_bookshelf_entry"}",
                     bookshelf_entry:,
                     show_status: true,
                     show_move_control: false,
                     show_sort_handle: false %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-stone-500"><%= t("users.library.empty_bookshelf_preview") %></p>
  <% end %>
</section>
