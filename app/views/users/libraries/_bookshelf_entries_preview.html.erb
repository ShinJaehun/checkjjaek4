<section class="rounded-2xl border border-stone-200 bg-stone-50 p-4 shadow-sm">
  <h3 class="text-sm font-semibold text-stone-900"><%= bookshelf.name %></h3>

  <% if bookshelf_entries.any? %>
    <div class="mt-3 grid gap-2 sm:grid-cols-2">
      <% bookshelf_entries.each do |bookshelf_entry| %>
        <%= render "bookshelf_entries/bookshelf_entry_preview", bookshelf_entry: %>
      <% end %>
    </div>
  <% else %>
    <p class="mt-3 text-sm text-stone-500">아직 이 책장에 담긴 책이 없습니다.</p>
  <% end %>
</section>
