<section class="flex max-h-[90vh] shrink-0 flex-col rounded-2xl border-2 bg-stone-50 shadow-sm <%= bookshelf_panel_class(bookshelf) %>"
         style="width: 20rem"
         data-bookshelf-organize-target="column"
         data-bookshelf-organize-bookshelf-id="<%= bookshelf.id %>">
  <header class="flex items-start justify-between gap-3 border-b border-stone-200 bg-white p-3"
          data-action="dragover->bookshelf-organize#dragoverHeader drop->bookshelf-organize#dropOnHeader">
    <div class="min-w-0">
      <div class="flex flex-wrap items-center gap-2">
        <h2 class="truncate text-sm font-semibold text-stone-900"><%= bookshelf.name %></h2>
        <span class="rounded-full bg-stone-100 px-2 py-0.5 text-xs font-medium text-stone-600"><%= bookshelf_entry_count %></span>
      </div>
      <p class="mt-1 text-xs text-stone-500"><%= t("bookshelves.visibility.#{bookshelf.visibility}") %></p>
    </div>

    <button type="button"
            class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-stone-200 bg-white text-sm font-semibold text-stone-600"
            data-bookshelf-organize-target="toggle"
            data-action="bookshelf-organize#toggleColumn"
            aria-label="<%= t("users.library.toggle_bookshelf") %>">
      -
    </button>
  </header>

  <div class="min-h-32 overflow-y-auto p-3"
       data-bookshelf-organize-target="body">
    <div class="grid gap-3"
         data-bookshelf-organize-target="list"
         data-bookshelf-organize-bookshelf-id="<%= bookshelf.id %>">
      <% bookshelf_entries.each do |bookshelf_entry| %>
        <%= render "bookshelf_entries/compact_bookshelf_entry",
                   bookshelf_entry:,
                   show_status: true,
                   show_move_control: false,
                   show_sort_handle: true %>
      <% end %>
    </div>
  </div>
</section>
