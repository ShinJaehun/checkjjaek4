<section class="mx-auto flex w-full max-w-6xl flex-col gap-4">
  <header class="rounded-2xl border border-stone-200 bg-white p-4 shadow-sm">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex min-w-0 items-center gap-3">
        <%= user_avatar_image(@user, size: 128, alt: @user.name, class: "h-12 w-12 shrink-0 rounded-full object-cover") %>
        <div class="min-w-0">
          <h1 class="truncate text-2xl font-semibold tracking-tight text-stone-900"><%= t("users.library.organize_title") %></h1>
          <p class="mt-1 text-sm text-stone-500"><%= t("users.library.organize_description") %></p>
        </div>
      </div>

      <%= link_to t("users.library.back_to_library"),
                  user_library_path(@user, sort: "manual", view: "compact"),
                  class: "rounded-xl border border-stone-200 px-3 py-2 text-sm font-semibold text-stone-700" %>
    </div>
  </header>

  <section class="overflow-x-auto pb-2"
           data-controller="bookshelf-organize"
           data-bookshelf-organize-reorder-url-value="<%= reorder_bookshelf_entries_path(view: "compact") %>"
           aria-label="<%= t("users.library.organize_board_label") %>">
    <div class="flex gap-4">
      <% @organize_bookshelves.each do |bookshelf| %>
        <%= render "users/libraries/organize_bookshelf_column",
                   bookshelf: bookshelf,
                   bookshelf_entries: @organize_entries_by_bookshelf_id.fetch(bookshelf.id, []),
                   bookshelf_entry_count: @organize_bookshelf_entry_counts.fetch(bookshelf.id, 0) %>
      <% end %>
    </div>
  </section>
</section>
