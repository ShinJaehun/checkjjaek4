<% modal_mode = local_assigns[:modal_mode].presence %>
<% color_swatch_classes = {
  "stone" => "border-stone-300 bg-stone-300",
  "red" => "border-red-300 bg-red-300",
  "orange" => "border-orange-300 bg-orange-300",
  "yellow" => "border-yellow-300 bg-yellow-300",
  "green" => "border-green-300 bg-green-300",
  "blue" => "border-blue-300 bg-blue-300",
  "purple" => "border-purple-300 bg-purple-300",
  "pink" => "border-pink-300 bg-pink-300"
} %>

<div class="<%= "hidden" unless modal_mode %> fixed inset-0 z-50 flex items-end justify-center bg-stone-950/30 p-4 sm:items-center"
     data-bookshelf-management-modal-target="modal"
     data-action="click->bookshelf-management-modal#closeOnBackdrop"
     role="dialog"
     aria-modal="true"
     aria-label="<%= t("bookshelves.form.manage_title") %>">
  <section class="max-h-[90vh] w-full max-w-lg overflow-y-auto rounded-2xl bg-white p-5 shadow-xl">
    <div class="flex justify-end">
      <button type="button"
              class="rounded-full border border-stone-200 px-2.5 py-1 text-sm font-semibold text-stone-500"
              data-action="bookshelf-management-modal#close"
              aria-label="<%= t("bookshelves.actions.close") %>">
        ×
      </button>
    </div>

    <% if new_bookshelf.present? %>
      <div class="mt-5 <%= "hidden" unless modal_mode == "create" %>" data-bookshelf-management-modal-target="createPanel">
        <% if new_bookshelf.errors.any? %>
          <div class="mt-3 rounded-xl border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
            <ul class="list-disc pl-5">
              <% new_bookshelf.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with model: new_bookshelf, url: bookshelves_path, class: "mt-3 space-y-3" do |form| %>
          <%= hidden_field_tag :return_to, return_to %>

          <div>
            <%= form.label :name, t("bookshelves.form.name"), class: "block text-xs font-medium text-stone-500" %>
            <%= form.text_field :name,
                                placeholder: t("bookshelves.form.name_placeholder"),
                                class: "mt-1 w-full rounded-xl border border-stone-200 px-3 py-2 text-sm text-stone-900" %>
          </div>

          <div>
            <%= form.label :visibility, t("bookshelves.form.visibility"), class: "block text-xs font-medium text-stone-500" %>
            <%= form.select :visibility,
                            bookshelf_visibility_options.map { |visibility| [ t("bookshelves.visibility.#{visibility}"), visibility ] },
                            {},
                            class: "mt-1 w-full rounded-xl border border-stone-200 px-3 py-2 text-sm text-stone-900" %>
          </div>

          <div>
            <%= form.label :color_key, t("bookshelves.form.color_key"), class: "block text-xs font-medium text-stone-500" %>
            <div class="mt-2 flex flex-wrap gap-2">
              <% bookshelf_color_options.each do |color_key| %>
                <% color_name = t("bookshelves.color_keys.#{color_key}") %>
                <% radio_id = "bookshelf_create_color_key_#{color_key}" %>
                <%= label_tag radio_id, class: "cursor-pointer", title: color_name do %>
                  <%= form.radio_button :color_key, color_key, id: radio_id, class: "peer sr-only" %>
                  <span class="block h-7 w-7 rounded-full border <%= color_swatch_classes.fetch(color_key, "border-stone-300 bg-stone-300") %> ring-offset-2 peer-checked:ring-2 peer-checked:ring-stone-900">
                    <span class="sr-only"><%= color_name %></span>
                  </span>
                <% end %>
              <% end %>
            </div>
          </div>

          <%= form.submit t("bookshelves.actions.create"),
                          class: "w-full rounded-xl bg-stone-900 px-4 py-2 text-sm font-semibold text-white" %>
        <% end %>
      </div>
    <% end %>

    <% if managed_bookshelf.present? && !managed_bookshelf.is_default? %>
      <div class="mt-5 <%= "hidden" unless modal_mode == "edit" %>" data-bookshelf-management-modal-target="editPanel">
        <% if managed_bookshelf.errors.any? %>
          <div class="mt-3 rounded-xl border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
            <ul class="list-disc pl-5">
              <% managed_bookshelf.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with model: managed_bookshelf, class: "mt-3 space-y-3" do |form| %>
          <%= hidden_field_tag :return_to, return_to %>

          <div>
            <%= form.label :name, t("bookshelves.form.name"), class: "block text-xs font-medium text-stone-500" %>
            <%= form.text_field :name,
                                class: "mt-1 w-full rounded-xl border border-stone-200 px-3 py-2 text-sm text-stone-900" %>
          </div>

          <div>
            <%= form.label :visibility, t("bookshelves.form.visibility"), class: "block text-xs font-medium text-stone-500" %>
            <%= form.select :visibility,
                            bookshelf_visibility_options.map { |visibility| [ t("bookshelves.visibility.#{visibility}"), visibility ] },
                            {},
                            class: "mt-1 w-full rounded-xl border border-stone-200 px-3 py-2 text-sm text-stone-900" %>
          </div>

          <div>
            <%= form.label :color_key, t("bookshelves.form.color_key"), class: "block text-xs font-medium text-stone-500" %>
            <div class="mt-2 flex flex-wrap gap-2">
              <% bookshelf_color_options.each do |color_key| %>
                <% color_name = t("bookshelves.color_keys.#{color_key}") %>
                <% radio_id = "bookshelf_edit_color_key_#{color_key}" %>
                <%= label_tag radio_id, class: "cursor-pointer", title: color_name do %>
                  <%= form.radio_button :color_key, color_key, id: radio_id, class: "peer sr-only" %>
                  <span class="block h-7 w-7 rounded-full border <%= color_swatch_classes.fetch(color_key, "border-stone-300 bg-stone-300") %> ring-offset-2 peer-checked:ring-2 peer-checked:ring-stone-900">
                    <span class="sr-only"><%= color_name %></span>
                  </span>
                <% end %>
              <% end %>
            </div>
          </div>

          <%= form.submit t("bookshelves.actions.update"),
                          class: "w-full rounded-xl bg-stone-900 px-4 py-2 text-sm font-semibold text-white" %>
        <% end %>

        <% order_controls = bookshelf_order_controls.fetch(managed_bookshelf.id, {}) %>
        <% if order_controls[:move_up] || order_controls[:move_down] %>
          <div class="mt-4 flex flex-wrap gap-2">
            <% if order_controls[:move_up] %>
              <%= button_to t("bookshelves.actions.move_up"),
                            move_up_bookshelf_path(managed_bookshelf),
                            method: :patch,
                            params: { return_to: return_to },
                            class: "rounded-xl border border-stone-200 px-4 py-2 text-sm font-semibold text-stone-700" %>
            <% end %>

            <% if order_controls[:move_down] %>
              <%= button_to t("bookshelves.actions.move_down"),
                            move_down_bookshelf_path(managed_bookshelf),
                            method: :patch,
                            params: { return_to: return_to },
                            class: "rounded-xl border border-stone-200 px-4 py-2 text-sm font-semibold text-stone-700" %>
            <% end %>
          </div>
        <% end %>

        <% if bookshelf_entry_counts.fetch(managed_bookshelf.id, 0).zero? %>
          <%= button_to t("bookshelves.actions.destroy"),
                        bookshelf_path(managed_bookshelf),
                        method: :delete,
                        params: { return_to: return_to },
                        form: { data: { turbo_confirm: t("bookshelves.confirm_destroy") } },
                        class: "mt-4 rounded-xl border border-red-200 px-4 py-2 text-sm font-semibold text-red-700" %>
        <% else %>
          <p class="mt-4 rounded-xl border border-stone-200 bg-stone-50 px-3 py-2 text-sm text-stone-600">
            <%= t("bookshelves.alerts.not_empty") %>
          </p>
        <% end %>
      </div>
    <% end %>
  </section>
</div>
