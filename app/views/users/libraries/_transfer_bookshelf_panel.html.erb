<%
  panel_role = local_assigns.fetch(:panel_role)
  target_panel = panel_role == :target
%>

<section class="mt-2 animate-[fade-slide-in_180ms_ease-out] space-y-0">
  <div class="relative z-10 hidden md:block">
    <nav class="flex items-end gap-1 overflow-x-auto px-2 pt-1 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
         aria-label="<%= t("users.library.transfer.choose_#{panel_role}") %>">
      <% bookshelves.each do |candidate| %>
        <% selected = candidate == bookshelf %>
        <% path =
          if target_panel
            transfer_path_for(source_bookshelf: paired_bookshelf, target_bookshelf: candidate, changed: "target")
          else
            transfer_path_for(source_bookshelf: candidate, target_bookshelf: paired_bookshelf, changed: "source")
          end %>

        <%= link_to path,
                    class: [
                      "inline-flex shrink-0 items-center gap-1 whitespace-nowrap rounded-t-xl border-2 px-4 py-1.5 text-sm font-semibold transition",
                      ("max-w-48" unless selected),
                      (selected ? "relative z-20 -mb-[2px]" : "relative z-0"),
                      bookshelf_tab_class(candidate, selected: selected)
                    ].compact do %>
          <span class="<%= selected ? "whitespace-nowrap" : "min-w-0 truncate" %>"><%= candidate.name %></span>
          <span class="shrink-0 <%= bookshelf_tab_count_class(candidate, selected: selected) %>">(<%= bookshelf_entry_counts.fetch(candidate.id, 0) %>)</span>
        <% end %>
      <% end %>
    </nav>
  </div>

  <section class="mt-0.5 overflow-hidden rounded-b-2xl rounded-tr-2xl border-2 bg-white shadow-sm ring-2 <%= bookshelf_panel_class(bookshelf) %>">
    <header class="border-b border-stone-100 px-4 py-3 <%= bookshelf_header_class(bookshelf) %>"
          <% if target_panel %>
            data-bookshelf-transfer-target="append"
            data-bookshelf-transfer-bookshelf-id="<%= bookshelf.id %>"
            data-action="dragover->bookshelf-transfer#dragoverAppend drop->bookshelf-transfer#dropOnAppend"
          <% end %>>
    <div class="flex flex-wrap items-center gap-2">
      <h2 class="sr-only"><%= t("users.library.transfer.#{target_panel ? "target_label" : "source_label"}") %></h2>
      <p class="break-words text-xl font-semibold text-stone-900"><%= bookshelf.name %></p>
      <span class="rounded-full bg-stone-100 px-2.5 py-1 text-xs font-medium text-stone-600">
        <%= bookshelf_entry_count %>
      </span>
    </div>
    </header>

    <div class="p-3">
      <div class="grid min-h-32 grid-cols-2 gap-3 sm:grid-cols-3 md:[grid-template-columns:repeat(auto-fill,10rem)] lg:[grid-template-columns:repeat(auto-fill,11rem)]"
           data-bookshelf-transfer-target="list"
           data-bookshelf-transfer-bookshelf-id="<%= bookshelf.id %>"
           data-bookshelf-transfer-list-role="<%= panel_role %>">
        <% bookshelf_entries.each do |bookshelf_entry| %>
          <%= render "bookshelf_entries/compact_bookshelf_entry",
                     bookshelf_entry:,
                     show_status: true,
                     show_move_control: false,
                     show_sort_handle: true,
                     show_transfer_selection: !target_panel %>
        <% end %>
      </div>

      <% if bookshelf_entries.empty? %>
        <p class="mt-3 rounded-2xl border border-dashed border-stone-300 bg-white p-4 text-sm text-stone-500">
          <%= t("users.library.empty_bookshelf_preview") %>
        </p>
      <% end %>
    </div>
  </section>
</section>
