<section class="mx-auto flex w-full max-w-4xl flex-col gap-4">
  <header class="rounded-2xl border border-stone-200 bg-white p-4 shadow-sm" data-library-summary>
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex min-w-0 items-center gap-3">
        <%= user_avatar_image(@user, size: 128, alt: @user.name, class: "h-12 w-12 shrink-0 rounded-full object-cover") %>
        <div class="min-w-0">
          <h1 class="truncate text-2xl font-semibold tracking-tight text-stone-900"><%= t("users.library.title_with_name", name: @user.name) %></h1>
          <% if current_user != @user %>
            <p class="mt-1 text-sm text-stone-500"><%= t("users.library.book_friend_read_only_notice") %></p>
          <% end %>
        </div>
      </div>

      <% if current_user == @user && @profile_bookshelves&.size.to_i > 1 %>
        <%= link_to t("users.library.transfer.open"),
                    transfer_user_library_path(@user, source_bookshelf_id: @selected_bookshelf&.id),
                    class: "shrink-0 rounded-xl border border-stone-200 px-3 py-2 text-sm font-semibold text-stone-700" %>
      <% end %>
    </div>
  </header>

  <% if @show_bookshelf %>
    <%= render "users/bookshelf_section",
               user: @user,
               bookshelves: @profile_bookshelves,
               selected_bookshelf: @selected_bookshelf,
               bookshelf_entries: @bookshelf_entries,
               bookshelf_entry_counts: @profile_bookshelf_entry_counts,
               bookshelf_sort: @profile_bookshelf_sort,
               bookshelf_sort_options: @profile_bookshelf_sort_options,
               show_status: @show_profile_bookshelf_status,
               show_move_control: @show_profile_bookshelf_move_control,
               show_create_form: @show_profile_bookshelf_create_form,
               new_bookshelf: @bookshelf,
               managed_bookshelf: @managed_bookshelf,
               bookshelf_management_modal_mode: @bookshelf_management_modal_mode,
               bookshelf_order_controls: @profile_bookshelf_order_controls,
               bookshelf_visibility_options: @profile_bookshelf_visibility_options,
               bookshelf_color_options: @profile_bookshelf_color_options,
               bookshelf_view: "detail" %>
  <% end %>
</section>
