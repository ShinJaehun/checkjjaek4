<% bookshelf_entry_count = local_assigns[:bookshelf_entry_count] || bookshelf_entries.size %>
<% bookshelf_view = local_assigns[:bookshelf_view] || "detail" %>
<% bookshelf_sort = local_assigns[:bookshelf_sort] || "manual" %>
<% target_options = Array(local_assigns[:bookshelves]).reject { |candidate| candidate == local_assigns[:selected_bookshelf] } %>

<section class="mt-4 rounded-2xl border-2 border-dashed border-stone-300 bg-stone-50 p-4">
  <header class="mb-3 space-y-3">
    <div class="flex flex-wrap items-center gap-2">
      <p class="text-sm font-semibold text-stone-500"><%= t("users.library.cross_shelf_target.label") %></p>
      <h3 class="break-words text-lg font-semibold text-stone-900"><%= bookshelf.name %></h3>
      <span class="rounded-full bg-white px-2.5 py-1 text-xs font-medium text-stone-600">
        <%= bookshelf_entry_count %>
      </span>
    </div>

    <nav class="flex flex-wrap gap-1.5" aria-label="<%= t("users.library.cross_shelf_target.choose") %>">
      <% target_options.each do |target_bookshelf| %>
        <%= link_to target_bookshelf.name,
                    user_library_path(user, bookshelf_id: selected_bookshelf.id, target_bookshelf_id: target_bookshelf.id, sort: bookshelf_sort, view: bookshelf_view),
                    class: [
                      "rounded-full border px-3 py-1.5 text-xs font-semibold",
                      (target_bookshelf == bookshelf ? "border-stone-900 bg-stone-900 text-white" : "border-stone-200 bg-white text-stone-600 hover:border-stone-400 hover:text-stone-900")
                    ] %>
      <% end %>
    </nav>
  </header>

  <div class="grid min-h-32 gap-3 <%= bookshelf_view == "compact" ? "grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5" : "sm:grid-cols-2" %>"
       data-cross-shelf-sortable-target="list"
       data-cross-shelf-sortable-bookshelf-id="<%= bookshelf.id %>">
    <% bookshelf_entries.each do |bookshelf_entry| %>
      <%= render "bookshelf_entries/#{bookshelf_view == "compact" ? "compact_bookshelf_entry" : "profile_bookshelf_entry"}",
                 bookshelf_entry:,
                 show_status: true,
                 show_move_control: false,
                 show_sort_handle: true %>
    <% end %>
  </div>
</section>
