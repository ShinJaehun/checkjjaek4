<% bookshelf_entry_count = local_assigns[:bookshelf_entry_count] || bookshelf_entries.size %>
<% bookshelf_view = local_assigns[:bookshelf_view] || "detail" %>

<section class="mt-4 rounded-2xl border-2 border-dashed border-stone-300 bg-stone-50 p-4">
  <header class="mb-3 flex flex-wrap items-center gap-2">
    <h3 class="break-words text-lg font-semibold text-stone-900"><%= bookshelf.name %></h3>
    <span class="rounded-full bg-white px-2.5 py-1 text-xs font-medium text-stone-600">
      <%= bookshelf_entry_count %>
    </span>
    <span class="rounded-full border border-stone-200 bg-white px-2.5 py-1 text-xs font-medium text-stone-500">
      SortableJS spike target
    </span>
  </header>

  <div class="grid min-h-32 gap-3 <%= bookshelf_view == "compact" ? "grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5" : "sm:grid-cols-2" %>"
       data-cross-shelf-sortable-target="list"
       data-cross-shelf-sortable-bookshelf-id="<%= bookshelf.id %>">
    <% bookshelf_entries.each do |bookshelf_entry| %>
      <%= render "bookshelf_entries/#{bookshelf_view == "compact" ? "compact_bookshelf_entry" : "profile_bookshelf_entry"}",
                 bookshelf_entry:,
                 show_status: true,
                 show_move_control: false,
                 show_sort_handle: true %>
    <% end %>
  </div>
</section>
