<section class="space-y-4">
  <div>
    <h2 class="text-2xl font-semibold tracking-tight text-stone-900"><%= t("users.profile.activity_title") %></h2>
  </div>

  <% if activity_items.any? %>
    <% activity_items.each do |activity_item| %>
      <% if activity_item.is_a?(Jjaek) %>
        <%= render "jjaeks/jjaek", jjaek: activity_item, inline_comments_context: :profile, inline_comments_profile_user: user %>
      <% else %>
        <%= render "book_activities/book_activity", book_activity: activity_item %>
      <% end %>
    <% end %>
  <% else %>
    <section class="rounded-[2rem] border border-dashed border-stone-300 bg-white p-6 text-sm text-stone-500 shadow-sm">
      <%= t("users.profile.empty_activity") %>
    </section>
  <% end %>
</section>
