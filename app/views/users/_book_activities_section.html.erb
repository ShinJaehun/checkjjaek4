<section class="space-y-4">
  <div>
    <p class="text-sm uppercase tracking-[0.3em] text-stone-400"><%= t("book_activities.profile.eyebrow") %></p>
    <h2 class="mt-2 text-2xl font-semibold tracking-tight text-stone-900"><%= t("book_activities.profile.title") %></h2>
  </div>

  <% if book_activities.any? %>
    <div class="space-y-3">
      <% book_activities.each do |book_activity| %>
        <article class="rounded-[2rem] border border-stone-200 bg-white p-5 text-sm text-stone-700 shadow-sm">
          <p><%= book_activity_message(book_activity) %></p>
          <p class="mt-2 text-xs text-stone-400"><%= l(book_activity.created_at, format: :short) %></p>
        </article>
      <% end %>
    </div>
  <% else %>
    <section class="rounded-[2rem] border border-dashed border-stone-300 bg-white p-6 text-sm text-stone-500 shadow-sm">
      <%= t("book_activities.profile.empty") %>
    </section>
  <% end %>
</section>
