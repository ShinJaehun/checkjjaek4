<article class="rounded-3xl border border-stone-300 bg-stone-100/70 p-5 text-sm text-stone-700 shadow-sm">
  <div class="flex gap-4">
    <%= render "books/thumbnail",
               title: book_activity.book.title,
               thumbnail: book_activity.book.thumbnail,
               url: book_path(book_activity.book),
               size: :small %>

    <div class="min-w-0 flex-1">
      <div class="flex items-start gap-3">
        <%= user_avatar_image(book_activity.user, size: 128, alt: book_activity.user.name, class: "h-9 w-9 shrink-0 rounded-full object-cover") %>
        <p class="leading-6"><%= book_activity_card_message(book_activity) %></p>
      </div>
      <p class="mt-2 text-xs text-stone-400"><%= l(book_activity.created_at, format: :short) %></p>
    </div>
  </div>
</article>
