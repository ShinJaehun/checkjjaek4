<article class="rounded-3xl border border-stone-200 bg-white p-5 text-sm text-stone-700 shadow-sm">
  <div class="flex gap-4">
    <%= link_to book_path(book_activity.book), class: "shrink-0" do %>
      <% if book_activity.book.thumbnail.present? %>
        <%= image_tag book_activity.book.thumbnail, alt: book_activity.book.title, class: "h-20 w-14 rounded-xl border border-stone-200 object-cover" %>
      <% else %>
        <div class="flex h-20 w-14 items-center justify-center rounded-xl border border-dashed border-stone-300 bg-stone-50 px-2 text-center text-[0.65rem] font-medium leading-4 text-stone-400">
          <%= t("book_activities.card.no_thumbnail") %>
        </div>
      <% end %>
    <% end %>

    <div class="min-w-0 flex-1">
      <p class="leading-6"><%= book_activity_card_message(book_activity) %></p>
      <p class="mt-2 text-xs text-stone-400"><%= l(book_activity.created_at, format: :short) %></p>
    </div>
  </div>
</article>
