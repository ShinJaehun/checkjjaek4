<section class="mx-auto flex w-full max-w-5xl flex-col gap-6">
  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <p class="text-sm uppercase tracking-[0.3em] text-stone-400"><%= t("bookshelf_entries.index.eyebrow") %></p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight text-stone-900"><%= t("bookshelf_entries.index.title") %></h1>
    <p class="mt-3 text-sm text-stone-500"><%= t("bookshelf_entries.index.description") %></p>
  </section>

  <% if @bookshelf_entries.any? %>
    <div class="grid gap-4 md:grid-cols-2">
      <% @bookshelf_entries.each do |entry| %>
        <%= render "bookshelf_entry", bookshelf_entry: entry %>
      <% end %>
    </div>
  <% else %>
    <section class="rounded-[2rem] border border-dashed border-stone-300 bg-white p-6 text-sm text-stone-500 shadow-sm">
      <%= t("bookshelf_entries.index.empty") %>
    </section>
  <% end %>
</section>
