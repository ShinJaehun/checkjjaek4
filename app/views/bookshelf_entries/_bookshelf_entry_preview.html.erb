<article class="rounded-xl border border-stone-200 bg-white p-3">
  <div class="flex gap-3">
    <%= render "books/thumbnail",
               title: bookshelf_entry.book.title,
               thumbnail: bookshelf_entry.book.thumbnail,
               url: book_path(bookshelf_entry.book),
               size: :small %>

    <div class="min-w-0">
      <p class="truncate text-sm font-semibold text-stone-900"><%= bookshelf_entry.book.title %></p>
      <p class="mt-1 truncate text-xs text-stone-500"><%= bookshelf_entry.book.authors_text.presence || "-" %></p>
    </div>
  </div>
</article>
