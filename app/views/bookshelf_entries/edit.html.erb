<section class="mx-auto flex w-full max-w-3xl flex-col gap-6">
  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <h1 class="text-3xl font-semibold tracking-tight text-stone-900"><%= t("bookshelf_entries.edit.title") %></h1>
    <p class="mt-2 text-sm text-stone-500"><%= @book.title %></p>

    <div class="mt-6">
      <%= render "form",
                 bookshelf_entry: @bookshelf_entry,
                 book: @book,
                 sticker_definitions: @sticker_definitions,
                 submit_label: t("bookshelf_entries.actions.update") %>
    </div>
  </section>
</section>
