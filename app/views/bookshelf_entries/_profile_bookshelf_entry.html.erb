<%
  metadata = [ bookshelf_entry.book.authors_text.presence, bookshelf_entry.book.publisher.presence ].compact.join(" · ").presence || "-"
  sticker_names = bookshelf_entry.sticker_definitions.map(&:name)
%>

<article class="h-full min-h-36 rounded-2xl border border-stone-200 bg-white p-3 shadow-sm <%= "cursor-grab active:cursor-grabbing" if local_assigns.fetch(:show_sort_handle, false) %>"
         data-bookshelf-entry-id="<%= bookshelf_entry.id %>"
         data-bookshelf-entry-view="detail"
         <% if local_assigns.fetch(:show_sort_handle, false) %>
           data-bookshelf-entries-sort-handle
         <% end %>>
  <div class="flex h-full gap-3">
    <div class="flex w-20 shrink-0 justify-center"
         <% if local_assigns.fetch(:show_sort_handle, false) %>
           data-bookshelf-entries-sort-handle
         <% end %>>
      <%= render "books/thumbnail",
                 title: bookshelf_entry.book.title,
                 thumbnail: bookshelf_entry.book.thumbnail,
                 url: book_path(bookshelf_entry.book),
                 link: false,
                 size: :medium %>
    </div>

    <div class="flex min-w-0 flex-1 flex-col">
      <div class="min-w-0">
        <%= link_to bookshelf_entry.book.title, book_path(bookshelf_entry.book), class: "block truncate text-sm font-semibold leading-5 text-stone-900 hover:text-stone-700" %>
        <p class="mt-1 truncate text-sm text-stone-500"><%= metadata %></p>
      </div>

      <% if local_assigns.fetch(:show_status, false) && (bookshelf_entry.status.present? || bookshelf_entry.sticker_definitions.any?) %>
        <div class="mt-auto flex flex-wrap items-center gap-1.5 pt-3">
          <% if bookshelf_entry.status.present? %>
            <span class="rounded-full bg-stone-100 px-3 py-1 text-xs font-medium text-stone-700"><%= t("bookshelf_entries.statuses.#{bookshelf_entry.status}") %></span>
          <% end %>

          <% bookshelf_entry.sticker_definitions.first(2).each do |sticker| %>
            <span class="rounded-full border border-stone-300 px-2.5 py-1 text-xs text-stone-600"><%= sticker.name %></span>
          <% end %>
          <% if bookshelf_entry.sticker_definitions.size > 2 %>
            <span class="rounded-full border border-stone-200 px-2.5 py-1 text-xs text-stone-400"
                  title="<%= sticker_names.join(", ") %>"
                  aria-label="스티커: <%= sticker_names.join(", ") %>">+<%= bookshelf_entry.sticker_definitions.size - 2 %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</article>
