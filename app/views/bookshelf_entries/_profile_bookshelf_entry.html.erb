<article class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
  <div class="flex gap-4">
    <% if bookshelf_entry.book.thumbnail.present? %>
      <img src="<%= bookshelf_entry.book.thumbnail %>" alt="<%= bookshelf_entry.book.title %>" class="w-20 rounded-2xl border border-stone-200 object-cover" />
    <% end %>

    <div class="min-w-0 flex-1">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <%= link_to bookshelf_entry.book.title, book_path(bookshelf_entry.book), class: "text-lg font-semibold text-stone-900 hover:text-stone-700" %>
          <p class="mt-1 text-sm text-stone-500"><%= bookshelf_entry.book.authors_text.presence || "-" %></p>

          <% if bookshelf_entry.book.publisher.present? %>
            <p class="mt-1 text-xs text-stone-400"><%= bookshelf_entry.book.publisher %></p>
          <% end %>
        </div>

        <% if local_assigns.fetch(:show_status, false) %>
          <span class="rounded-full bg-stone-100 px-3 py-1 text-xs font-medium text-stone-700"><%= t("bookshelf_entries.statuses.#{bookshelf_entry.status}") %></span>
        <% end %>
      </div>
    </div>
  </div>
</article>
