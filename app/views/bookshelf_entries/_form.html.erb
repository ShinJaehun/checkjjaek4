<%= form_with model: bookshelf_entry, class: "space-y-4" do |form| %>
  <% if bookshelf_entry.errors.any? %>
    <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      <%= bookshelf_entry.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="space-y-2">
    <label class="text-sm font-medium text-stone-700"><%= t("bookshelf_entries.form.book") %></label>
    <div class="rounded-2xl bg-stone-50 px-4 py-3 text-sm text-stone-700">
      <div class="font-medium text-stone-900"><%= book.title %></div>
      <div class="mt-1 text-stone-500"><%= book.authors_text.presence || "-" %></div>
    </div>
  </div>

  <%= bookshelf_entry_book_hidden_fields(book) %>

  <div class="space-y-2">
    <%= form.label :status, t("bookshelf_entries.form.status"), class: "text-sm font-medium text-stone-700" %>
    <%= form.select :status,
                    BookshelfEntry.statuses.keys.map { |status| [t("bookshelf_entries.statuses.#{status}"), status] },
                    {},
                    class: "w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm shadow-sm focus:border-stone-500 focus:outline-none" %>
  </div>

  <div class="space-y-2">
    <span class="text-sm font-medium text-stone-700"><%= t("bookshelf_entries.form.stickers") %></span>
    <div class="flex flex-wrap gap-2">
      <%= form.collection_check_boxes :sticker_definition_ids, sticker_definitions, :id, :name do |builder| %>
        <label class="inline-flex items-center gap-2 rounded-full border border-stone-300 px-3 py-1.5 text-sm text-stone-700">
          <%= builder.check_box class: "rounded border-stone-300 text-stone-900 focus:ring-stone-500" %>
          <span><%= builder.text %></span>
        </label>
      <% end %>
    </div>
  </div>

  <%= form.submit submit_label, class: "rounded-full bg-stone-900 px-4 py-2 text-sm font-medium text-stone-50" %>
<% end %>
