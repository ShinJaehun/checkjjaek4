<section class="mx-auto w-full max-w-2xl rounded-[2rem] border border-stone-200 bg-white p-8 shadow-sm">
  <h1 class="text-3xl font-semibold tracking-tight text-stone-900"><%= t("auth.registrations.title") %></h1>
  <p class="mt-2 text-sm leading-6 text-stone-500"><%= t("auth.registrations.description") %></p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-8 space-y-4" }) do |form| %>
    <% if resource.errors.any? %>
      <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
        <%= resource.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="space-y-2">
      <%= form.label :name, t("auth.form.name"), class: "text-sm font-medium text-stone-700" %>
      <%= form.text_field :name, class: "w-full rounded-2xl border border-stone-300 px-4 py-3 text-sm" %>
    </div>

    <div class="space-y-2">
      <%= form.label :email, t("auth.form.email"), class: "text-sm font-medium text-stone-700" %>
      <%= form.email_field :email, autocomplete: "email", class: "w-full rounded-2xl border border-stone-300 px-4 py-3 text-sm" %>
    </div>

    <div class="space-y-2">
      <%= form.label :password, t("auth.form.password"), class: "text-sm font-medium text-stone-700" %>
      <%= form.password_field :password, autocomplete: "new-password", class: "w-full rounded-2xl border border-stone-300 px-4 py-3 text-sm" %>
    </div>

    <div class="space-y-2">
      <%= form.label :password_confirmation, t("auth.form.password_confirmation"), class: "text-sm font-medium text-stone-700" %>
      <%= form.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-2xl border border-stone-300 px-4 py-3 text-sm" %>
    </div>

    <%= form.submit t("auth.actions.sign_up"), class: "w-full rounded-full bg-stone-900 px-4 py-3 text-sm font-medium text-stone-50" %>
  <% end %>
</section>
