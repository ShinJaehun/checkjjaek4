<section class="mx-auto grid w-full max-w-5xl gap-6 lg:grid-cols-[1.1fr_0.9fr]">
  <div class="rounded-[2.5rem] bg-stone-900 px-8 py-10 text-stone-50 shadow-xl">
    <p class="text-sm uppercase tracking-[0.3em] text-stone-300"><%= t("auth.sessions.eyebrow") %></p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight"><%= t("auth.sessions.title") %></h1>
    <p class="mt-4 max-w-xl text-sm leading-7 text-stone-300"><%= t("auth.sessions.description") %></p>
  </div>

  <div class="rounded-[2rem] border border-stone-200 bg-white p-8 shadow-sm">
    <h2 class="text-xl font-semibold text-stone-900"><%= t("auth.actions.sign_in") %></h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-6 space-y-4" }) do |form| %>
      <div class="space-y-2">
        <%= form.label :email, t("auth.form.email"), class: "text-sm font-medium text-stone-700" %>
        <%= form.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-2xl border border-stone-300 px-4 py-3 text-sm" %>
      </div>

      <div class="space-y-2">
        <%= form.label :password, t("auth.form.password"), class: "text-sm font-medium text-stone-700" %>
        <%= form.password_field :password, autocomplete: "current-password", class: "w-full rounded-2xl border border-stone-300 px-4 py-3 text-sm" %>
      </div>

      <%= form.submit t("auth.actions.sign_in"), class: "w-full rounded-full bg-stone-900 px-4 py-3 text-sm font-medium text-stone-50" %>
    <% end %>

    <p class="mt-6 text-sm text-stone-500">
      <%= t("auth.sessions.no_account") %>
      <%= link_to t("auth.actions.sign_up"), new_user_registration_path, class: "font-medium text-stone-900" %>
    </p>
  </div>
</section>
