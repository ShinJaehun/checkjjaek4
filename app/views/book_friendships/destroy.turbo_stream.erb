<%= turbo_stream.replace @relationship_section_id do %>
  <%= render "relationships/section",
             section_id: @relationship_section_id,
             section_class: @relationship_section_class,
             title: @relationship_section_title,
             collection: @relationship_section_collection,
             row_partial: @relationship_section_row_partial,
             row_locals: @relationship_section_row_locals,
             empty_message: @relationship_section_empty_message %>
<% end %>

<%= turbo_stream.update "flash-messages" do %>
  <%= render "shared/flash" %>
<% end %>
