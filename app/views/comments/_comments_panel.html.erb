<section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
  <h2 class="text-lg font-semibold text-stone-900"><%= t("comments.title") %></h2>

  <div class="mt-4 space-y-4">
    <% comments.each do |comment_record| %>
      <%= render "comments/comment", jjaek: jjaek, comment: comment_record %>
    <% end %>
  </div>

  <div class="mt-6">
    <%= render "comments/form", jjaek: jjaek, comment: comment %>
  </div>
</section>
