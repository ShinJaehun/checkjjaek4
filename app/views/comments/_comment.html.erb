<% comments_context = local_assigns.fetch(:comments_context, :detail) %>
<% comments_profile_user = local_assigns[:comments_profile_user] %>
<% comments_book = local_assigns[:comments_book] %>
<% destroy_comments_params = { comments_context: comments_context } %>
<% destroy_comments_params[:profile_user_id] = comments_profile_user.id if comments_profile_user.present? %>
<% destroy_comments_params[:book_id] = comments_book.id if comments_book.present? %>

<article class="rounded-2xl bg-stone-50 px-4 py-3">
  <div class="flex items-center justify-between gap-3">
    <div class="flex min-w-0 items-center gap-2">
      <%= user_avatar_image(comment.user, size: 128, alt: comment.user.name, class: "h-8 w-8 shrink-0 rounded-full object-cover") %>
      <div class="text-sm font-medium text-stone-800"><%= comment.user.name %></div>
    </div>
    <% if comment.user == current_user %>
      <%= button_to t("comments.actions.delete"),
                    jjaek_comment_path(jjaek, comment),
                    method: :delete,
                    params: destroy_comments_params,
                    class: "text-xs text-red-600" %>
    <% end %>
  </div>
  <p class="mt-2 text-sm leading-6 text-stone-700"><%= comment.content %></p>
</article>
