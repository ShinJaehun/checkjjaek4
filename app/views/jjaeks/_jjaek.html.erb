<article class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
  <div class="flex items-start justify-between gap-3">
    <div>
      <div class="text-sm text-stone-600">
        <%= jjaek_context_label(jjaek) %>
      </div>
      <div class="mt-1 text-xs text-stone-500">
        <%= l(jjaek.created_at, format: :short) %>
        · <%= t("jjaeks.visibility.#{jjaek.visibility}") %>
        <% if show_requote_book_link?(jjaek) %>
          ·
          <%= link_to jjaek.book.title, book_path(jjaek.book), class: "font-medium hover:text-stone-700" %>
        <% end %>
      </div>
    </div>

    <% if jjaek.user == current_user %>
      <div class="flex items-center gap-2 text-xs text-stone-500">
        <%= link_to t("jjaeks.actions.edit"), edit_jjaek_path(jjaek) %>
        <%= button_to t("jjaeks.actions.delete"), jjaek_path(jjaek), method: :delete, form: { data: { turbo_confirm: t("jjaeks.confirmations.destroy") } }, class: "text-red-600" %>
      </div>
    <% end %>
  </div>

  <% if jjaek.book.present? %>
    <div class="mt-4 flex flex-col gap-4 sm:flex-row">
      <% if jjaek.book.thumbnail.present? %>
        <div class="shrink-0">
          <%= link_to image_tag(jjaek.book.thumbnail, alt: jjaek.book.title, class: "w-20 rounded-2xl border border-stone-200 object-cover sm:w-24"), book_path(jjaek.book) %>
        </div>
      <% end %>

      <div class="min-w-0 flex-1">
        <div class="rounded-2xl bg-stone-50 px-4 py-3">
          <%= link_to jjaek.book.title, book_path(jjaek.book), class: "text-sm font-medium text-stone-900 hover:text-stone-700" %>
          <div class="mt-1 text-xs text-stone-500"><%= jjaek.book.authors_text.presence || "-" %></div>
        </div>

        <% if jjaek.quoted_jjaek.present? %>
          <div class="mt-3">
            <%= render "jjaeks/quoted_jjaek", quoted_jjaek: jjaek.quoted_jjaek %>
          </div>
        <% end %>

        <div class="mt-3 whitespace-pre-wrap text-sm leading-6 text-stone-800"><%= jjaek.content %></div>
      </div>
    </div>
  <% else %>
    <% if jjaek.quoted_jjaek.present? %>
      <div class="mt-4">
        <%= render "jjaeks/quoted_jjaek", quoted_jjaek: jjaek.quoted_jjaek %>
      </div>
    <% end %>

    <div class="mt-4 whitespace-pre-wrap text-sm leading-6 text-stone-800"><%= jjaek.content %></div>
  <% end %>

  <div class="mt-4 flex flex-wrap items-center gap-4 text-xs text-stone-500">
    <span><%= t("jjaeks.meta.likes", count: jjaek.likes_count) %></span>
    <span><%= t("jjaeks.meta.comments", count: jjaek.comments_count) %></span>
    <% current_like = current_user_like_for(jjaek) %>
    <% if current_like %>
      <%= button_to t("likes.actions.unlike"), jjaek_like_path(jjaek), method: :delete, class: "text-sm font-medium text-stone-700" %>
    <% else %>
      <%= button_to t("likes.actions.like"), jjaek_like_path(jjaek), class: "text-sm font-medium text-stone-700" %>
    <% end %>
    <%= link_to t("jjaeks.actions.view"), jjaek_path(jjaek), class: "font-medium text-stone-700" %>
  </div>
</article>
