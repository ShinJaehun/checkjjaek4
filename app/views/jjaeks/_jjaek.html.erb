<% inline_comments_context = local_assigns[:inline_comments_context] %>
<% inline_comments_profile_user = local_assigns[:inline_comments_profile_user] %>
<% inline_comments_book = local_assigns[:inline_comments_book] %>

<article class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
  <%= render "jjaeks/jjaek_header", jjaek: jjaek %>
  <%= render "jjaeks/jjaek_body", jjaek: jjaek %>
  <%= render "jjaeks/jjaek_actions",
             jjaek: jjaek,
             inline_comments_context: inline_comments_context,
             inline_comments_profile_user: inline_comments_profile_user,
             inline_comments_book: inline_comments_book %>

  <% if inline_comments_context.present? %>
    <div id="<%= comments_panel_dom_id(jjaek, context: inline_comments_context, profile_user: inline_comments_profile_user, book: inline_comments_book) %>"></div>
  <% end %>
</article>
