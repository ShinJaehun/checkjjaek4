<% if jjaek.book.present? %>
  <div class="mt-4 flex flex-col items-start gap-4 sm:flex-row">
    <div class="shrink-0 self-start">
      <%= render "books/thumbnail",
                 title: jjaek.book.title,
                 thumbnail: jjaek.book.thumbnail,
                 url: book_path(jjaek.book),
                 size: :medium %>
    </div>

    <div class="min-w-0 flex-1">
      <div>
        <%= link_to jjaek.book.title, book_path(jjaek.book), class: "text-base font-semibold leading-6 text-stone-900 hover:text-stone-700" %>
        <div class="mt-1 text-xs leading-5 text-stone-500"><%= jjaek.book.authors_text.presence || "-" %></div>
      </div>

      <% if jjaek.quoted_jjaek.present? %>
        <div class="mt-3">
          <%= render "jjaeks/quoted_jjaek", quoted_jjaek: jjaek.quoted_jjaek %>
        </div>
      <% elsif jjaek.quoted_source_deleted? %>
        <div class="mt-3">
          <%= render "jjaeks/deleted_quoted_source", jjaek: jjaek %>
        </div>
      <% end %>

      <div class="mt-3 whitespace-pre-wrap text-sm leading-6 text-stone-800"><%= jjaek.content %></div>
    </div>
  </div>
<% else %>
  <% if jjaek.quoted_jjaek.present? %>
    <div class="mt-4">
      <%= render "jjaeks/quoted_jjaek", quoted_jjaek: jjaek.quoted_jjaek %>
    </div>
  <% elsif jjaek.quoted_source_deleted? %>
    <div class="mt-4">
      <%= render "jjaeks/deleted_quoted_source", jjaek: jjaek %>
    </div>
  <% end %>

  <div class="mt-4 whitespace-pre-wrap text-sm leading-6 text-stone-800"><%= jjaek.content %></div>
<% end %>
