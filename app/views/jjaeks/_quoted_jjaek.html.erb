<div class="rounded-2xl border border-stone-200 bg-stone-50/80 px-4 py-3 text-sm text-stone-600">
  <div class="flex items-center gap-2 text-xs font-medium text-stone-600">
    <%= user_avatar_image(quoted_jjaek.user, size: 128, alt: quoted_jjaek.user.name, class: "h-8 w-8 shrink-0 rounded-full object-cover") %>
    <span>
      <%= link_to quoted_jjaek.user.name, user_path(quoted_jjaek.user), class: "font-semibold text-stone-800 hover:text-stone-900" %><%= quoted_jjaek.book.present? ? t("jjaeks.labels.quoted_book_suffix") : t("jjaeks.labels.quoted_general_suffix") %>
    </span>
    <% if jjaek_edited?(quoted_jjaek) %>
      <span class="text-stone-400">·</span>
      <span class="text-stone-500"><%= t("jjaeks.meta.edited") %></span>
    <% end %>
  </div>

  <% if quoted_jjaek.book.present? %>
    <div class="mt-3 flex flex-col items-start gap-3 sm:flex-row">
      <div class="shrink-0 self-start">
        <%= render "books/thumbnail",
                   title: quoted_jjaek.book.title,
                   thumbnail: quoted_jjaek.book.thumbnail,
                   url: book_path(quoted_jjaek.book),
                   size: :small %>
      </div>

      <div class="min-w-0 flex-1">
        <%= link_to quoted_jjaek.book.title, book_path(quoted_jjaek.book), class: "text-sm font-semibold leading-5 text-stone-900 hover:text-stone-700" %>
        <div class="mt-1 text-xs leading-5 text-stone-500"><%= quoted_jjaek.book.authors_text.presence || "-" %></div>
        <p class="mt-2 line-clamp-4 whitespace-pre-wrap text-sm leading-6 text-stone-700"><%= quoted_jjaek.content %></p>
      </div>
    </div>
  <% else %>
    <p class="mt-3 line-clamp-4 whitespace-pre-wrap text-sm leading-6 text-stone-700"><%= quoted_jjaek.content %></p>
  <% end %>
</div>
