<div class="rounded-2xl bg-stone-50 px-4 py-3 text-sm text-stone-600">
  <div class="font-medium text-stone-900"><%= t("jjaeks.labels.requote", name: quoted_jjaek.user.name) %></div>

  <% if quoted_jjaek.book.present? %>
    <div class="mt-3 flex gap-3">
      <% if quoted_jjaek.book.thumbnail.present? %>
        <%= link_to image_tag(quoted_jjaek.book.thumbnail, alt: quoted_jjaek.book.title, class: "w-14 rounded-xl border border-stone-200 object-cover"), book_path(quoted_jjaek.book), class: "shrink-0" %>
      <% end %>

      <div class="min-w-0">
        <%= link_to quoted_jjaek.book.title, book_path(quoted_jjaek.book), class: "text-sm font-medium text-stone-900 hover:text-stone-700" %>
        <div class="mt-1 text-xs text-stone-500"><%= quoted_jjaek.book.authors_text.presence || "-" %></div>
      </div>
    </div>
  <% end %>

  <p class="mt-3 line-clamp-4 whitespace-pre-wrap"><%= quoted_jjaek.content %></p>
</div>
