<section class="mx-auto flex w-full max-w-3xl flex-col gap-6">
  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <% if @book.present? %>
      <div class="rounded-2xl bg-stone-50 px-4 py-4">
        <div class="text-sm font-medium text-stone-900"><%= @book.title %></div>
        <div class="mt-1 text-sm text-stone-500"><%= @book.authors_text.presence || "-" %></div>
      </div>
    <% end %>

    <% if @quoted_jjaek.present? %>
      <div class="<%= @book.present? ? "mt-4" : "" %>">
        <%= render "jjaeks/quoted_jjaek", quoted_jjaek: @quoted_jjaek %>
      </div>
    <% end %>

    <div class="mt-6">
      <%= form_with model: @jjaek, class: "space-y-4" do |form| %>
        <% if @jjaek.errors.any? %>
          <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            <%= @jjaek.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <%= form.hidden_field :book_id, value: @book.id if @book.present? %>
        <%= form.hidden_field :quoted_jjaek_id, value: @quoted_jjaek&.id %>

        <div class="space-y-2">
          <%= form.label :visibility, t("jjaeks.form.visibility"), class: "text-sm font-medium text-stone-700" %>
          <%= form.select :visibility,
                          @jjaek_visibility_options.map { |visibility| [t("jjaeks.visibility.#{visibility}"), visibility] },
                          {},
                          class: "w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm shadow-sm focus:border-stone-500 focus:outline-none" %>
        </div>

        <div class="space-y-2">
          <% content_label_key = if @quoted_jjaek.present?
                                  "jjaeks.form.requote_content"
                                elsif @book.present?
                                  "jjaeks.form.book_jjaek_content"
                                else
                                  "jjaeks.form.jjaek_content"
                                end %>
          <%= form.label :content, t(content_label_key), class: "sr-only" %>
          <%= form.text_area :content, rows: 8, class: "w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm shadow-sm focus:border-stone-500 focus:outline-none" %>
        </div>

        <%= form.submit @quoted_jjaek.present? ? t("jjaeks.actions.publish_requote") : t("jjaeks.actions.publish"), class: "rounded-full bg-stone-900 px-4 py-2 text-sm font-medium text-stone-50" %>
      <% end %>
    </div>
  </section>
</section>
