<section class="mx-auto flex w-full max-w-4xl flex-col gap-6">
  <section class="rounded-[2rem] bg-stone-900 px-6 py-8 text-stone-50 shadow-lg">
    <h1 class="text-3xl font-semibold tracking-tight"><%= t("home.title") %></h1>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-stone-300"><%= t("home.description") %></p>
    <div class="mt-5 flex flex-wrap gap-3">
      <%= link_to t("home.actions.search_books"), book_search_path, class: "rounded-full bg-white px-4 py-2 text-sm font-medium text-stone-900" %>
      <%= link_to t("home.actions.my_shelf"), bookshelf_entries_path, class: "rounded-full border border-stone-500 px-4 py-2 text-sm font-medium text-stone-50" %>
    </div>
  </section>

  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <%= form_with model: @jjaek, class: "space-y-4" do |form| %>
      <% if @jjaek.errors.any? %>
        <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
          <%= @jjaek.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <div class="space-y-2">
        <%= form.label :visibility, t("jjaeks.form.visibility"), class: "text-sm font-medium text-stone-700" %>
        <%= form.select :visibility,
                        Jjaek.visibilities.keys.map { |visibility| [t("jjaeks.visibility.#{visibility}"), visibility] },
                        {},
                        class: "w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm shadow-sm focus:border-stone-500 focus:outline-none" %>
      </div>

      <div class="space-y-2">
        <%= form.label :content, t("jjaeks.form.general_content"), class: "text-sm font-medium text-stone-700" %>
        <%= form.text_area :content, rows: 4, class: "w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm shadow-sm focus:border-stone-500 focus:outline-none" %>
      </div>

      <%= form.submit t("jjaeks.actions.publish_short"), class: "rounded-full bg-stone-900 px-4 py-2 text-sm font-medium text-stone-50" %>
    <% end %>
  </section>

  <section class="space-y-4">
    <div>
      <h2 class="text-2xl font-semibold tracking-tight text-stone-900"><%= t("home.feed_title") %></h2>
    </div>

    <% if @feed_items.any? %>
      <% @feed_items.each do |feed_item| %>
        <% if feed_item.is_a?(Jjaek) %>
          <%= render "jjaeks/jjaek", jjaek: feed_item %>
        <% else %>
          <%= render "book_activities/book_activity", book_activity: feed_item %>
        <% end %>
      <% end %>
    <% else %>
      <section class="rounded-[2rem] border border-dashed border-stone-300 bg-white p-6 text-sm text-stone-500 shadow-sm">
        <%= t("home.empty_feed") %>
      </section>
    <% end %>
  </section>
</section>
